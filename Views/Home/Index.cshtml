@{
    ViewData["Title"] = "Home Page";
}

<div class="hero">
    <div class="hero-overlay"></div>
    <img src="~/images/hero.png" 
         alt="Luxury Car" class="position-absolute w-100 h-100 object-fit-cover" style="z-index: 0;">
    
    <div class="hero-content animate-fade-in">
        <h1 class="hero-title">Louez la voiture de vos rêves en un clic.</h1>
        <p class="fs-4 mb-5 opacity-75">La plateforme multi-agences la plus fluide pour vos déplacements.</p>
        
        <div class="glass p-4 rounded-4 shadow-lg text-start mx-auto" style="max-width: 900px;">
            <form class="row g-3" asp-controller="Voitures" asp-action="Search" method="get">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-uppercase">Où ?</label>
                    <input type="text" name="ville" class="form-control-premium w-100" placeholder="Ville ou Agence">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase">Début</label>
                    <input type="date" name="debut" id="search-debut" class="form-control-premium w-100">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase">Fin</label>
                    <input type="date" name="fin" id="search-fin" class="form-control-premium w-100">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-premium w-100 py-3">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
            <div id="availability-preview" class="mt-3 small text-info d-none">
                <i class="bi bi-info-circle"></i> <span id="availability-text"></span>
            </div>
        </div>
    </div>
</div>

<section class="container py-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="card-premium h-100">
                <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
                <h3>Sécurité Garantie</h3>
                <p class="text-muted">Toutes nos voitures sont inspectées régulièrement par nos agences partenaires.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-premium h-100">
                <i class="bi bi-lightning-charge fs-1 text-primary mb-3"></i>
                <h3>Réservation Rapide</h3>
                <p class="text-muted">Réservez en moins de 2 minutes avec confirmation immédiate via SignalR.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-premium h-100">
                <i class="bi bi-gem fs-1 text-primary mb-3"></i>
                <h3>Programme Fidélité</h3>
                <p class="text-muted">Gagnez des points à chaque location et profitez de remises exclusives.</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Placeholder for OnDateChanged event logic
        document.getElementById('search-fin').addEventListener('change', function() {
            const debut = document.getElementById('search-debut').value;
            const fin = this.value;
            if (debut && fin) {
                const preview = document.getElementById('availability-preview');
                const text = document.getElementById('availability-text');
                preview.classList.remove('d-none');
                text.textContent = "Calcul de la disponibilité prédictive...";
                
                // Simulate async call (OnDateChanged)
                setTimeout(() => {
                    text.textContent = "12 voitures disponibles pour ces dates !";
                }, 800);
            }
        });
    </script>
}
