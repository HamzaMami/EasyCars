@using EasyCars.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Inscription";
    Layout = "_Layout";
}

<style>
    .auth-page { min-height: 100vh; display: flex; align-items: stretch; }
    .auth-panel-left {
        background: linear-gradient(135deg, #1e40af 0%, #2563eb 50%, #3b82f6 100%);
        flex: 1; display: flex; flex-direction: column;
        justify-content: center; align-items: center; padding: 3rem; color: white;
    }
    .auth-panel-right {
        flex: 1; display: flex; justify-content: center;
        align-items: center; padding: 3rem; background: var(--background);
    }
    .auth-card { width: 100%; max-width: 440px; }
    .auth-input {
        background: var(--card-bg) !important;
        border: 1.5px solid rgba(100,116,139,0.2) !important;
        border-radius: var(--radius) !important;
        padding: 0.85rem 1rem !important;
        color: var(--text) !important;
        font-size: 1rem; transition: all 0.2s ease;
    }
    .auth-input:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
        outline: none !important;
    }
</style>

<div class="auth-page">
    <!-- Left Panel -->
    <div class="auth-panel-left d-none d-lg-flex">
        <div class="text-center">
            <h1 class="fw-bold display-4 mb-3">EasyCars</h1>
            <p class="fs-5 opacity-75 mb-5">Rejoignez des milliers de membres<br>et profitez de nos offres exclusives.</p>
            <div class="card-premium bg-white bg-opacity-10 text-white border-0 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-gem me-2"></i> Programme Fidélité</h5>
                <div class="d-flex gap-3 justify-content-center">
                    <div class="text-center">
                        <div class="fs-2">🥉</div>
                        <div class="small fw-bold">Bronze</div>
                        <div class="small opacity-75">0 pts</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-2">🥈</div>
                        <div class="small fw-bold">Argent</div>
                        <div class="small opacity-75">-10%</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-2">🥇</div>
                        <div class="small fw-bold">Or</div>
                        <div class="small opacity-75">-20%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-panel-right">
        <div class="auth-card">
            <div class="mb-4">
                <h2 class="fw-bold mb-1">Créer un compte 🚀</h2>
                <p class="text-muted">Rejoignez EasyCars en quelques secondes</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="All" class="alert alert-danger mb-4 small"></div>

                <div class="mb-3">
                    <label asp-for="Nom" class="form-label fw-bold small text-uppercase text-muted">Nom complet</label>
                    <input asp-for="Nom" class="form-control auth-input" placeholder="Jean Dupont" />
                    <span asp-validation-for="Nom" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold small text-uppercase text-muted">Email</label>
                    <input asp-for="Email" class="form-control auth-input" placeholder="votre@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold small text-uppercase text-muted">Mot de passe</label>
                    <input asp-for="Password" class="form-control auth-input" placeholder="Minimum 6 caractères" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold small text-uppercase text-muted">Confirmer le mot de passe</label>
                    <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-premium w-100 py-3 fs-6 mb-4">
                    Créer mon compte <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <p class="text-center text-muted">
                Déjà un compte ?
                <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Se connecter</a>
            </p>
        </div>
    </div>
</div>