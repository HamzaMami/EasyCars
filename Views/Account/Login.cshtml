@using EasyCars.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "_Layout";
}

<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: stretch;
    }
    .auth-panel-left {
        background: linear-gradient(135deg, #1e40af 0%, #2563eb 50%, #3b82f6 100%);
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        color: white;
    }
    .auth-panel-right {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        background: var(--background);
    }
    .auth-card {
        width: 100%;
        max-width: 420px;
    }
    .auth-input {
        background: var(--card-bg) !important;
        border: 1.5px solid rgba(100,116,139,0.2) !important;
        border-radius: var(--radius) !important;
        padding: 0.85rem 1rem !important;
        color: var(--text) !important;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    .auth-input:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
        outline: none !important;
    }
</style>

<div class="auth-page">
    <!-- Left Panel -->
    <div class="auth-panel-left d-none d-lg-flex">
        <div class="text-center">
            <h1 class="fw-bold display-4 mb-3"><span>Easy</span>Cars</h1>
            <p class="fs-5 opacity-75 mb-5">La mobilité sans frontières,<br>à portée de clic.</p>
            <div class="d-flex flex-column gap-3 text-start">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white bg-opacity-25 p-3"><i class="bi bi-shield-check fs-5"></i></div>
                    <span>Sécurité et fiabilité garanties</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white bg-opacity-25 p-3"><i class="bi bi-gem fs-5"></i></div>
                    <span>Programme fidélité exclusif</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white bg-opacity-25 p-3"><i class="bi bi-lightning-charge fs-5"></i></div>
                    <span>Réservation en temps réel</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-panel-right">
        <div class="auth-card">
            <div class="mb-5">
                <h2 class="fw-bold mb-1">Bon retour 👋</h2>
                <p class="text-muted">Connectez-vous à votre compte EasyCars</p>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="alert alert-danger mb-4 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label fw-bold small text-uppercase text-muted">Email</label>
                    <input asp-for="Email" class="form-control auth-input" placeholder="votre@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-bold small text-uppercase text-muted">Mot de passe</label>
                    <input asp-for="Password" class="form-control auth-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                        <label asp-for="RememberMe" class="form-check-label small" for="rememberMe">Se souvenir de moi</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-premium w-100 py-3 fs-6 mb-4">
                    Se connecter <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <p class="text-center text-muted">
                Pas encore de compte ?
                <a asp-action="Register" class="text-primary fw-bold text-decoration-none">S'inscrire gratuitement</a>
            </p>
        </div>
    </div>
</div>