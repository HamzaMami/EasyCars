@model IEnumerable<EasyCars.Models.Feedback>

@{
    ViewData["Title"] = "Avis Clients";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5 animate-fade-in">
        <div>
            <h1 class="fw-bold">Avis Clients</h1>
            <p class="text-muted">Découvrez ce que nos clients pensent de nos véhicules et agences.</p>
        </div>
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-action="Create" class="btn btn-premium">
                <i class="bi bi-plus-lg"></i> Laisser un avis
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-square-heart fs-1 text-muted mb-3 d-block"></i>
            <h4 class="text-muted">Aucun avis pour l'instant</h4>
            <p class="text-muted">Soyez le premier à partager votre expérience !</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 animate-fade-in">
                    <div class="card-premium h-100 d-flex flex-column">
                        <!-- Star Rating -->
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex gap-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= item.Note)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-muted"></i>
                                    }
                                }
                                <span class="ms-1 fw-bold small">@item.Note/5</span>
                            </div>
                            <span class="text-muted small">@item.Date.ToString("dd/MM/yyyy")</span>
                        </div>

                        <!-- Comment -->
                        <p class="flex-grow-1 mb-3" style="font-style: italic; color: var(--text-muted);">
                            "@item.Commentaire"
                        </p>

                        <!-- Author + Target -->
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width:36px;height:36px;font-size:.85rem;">
                                    @item.Utilisateur.Nom.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-bold small">@item.Utilisateur.Nom</div>
                                    <div class="text-muted" style="font-size:.75rem;">@item.Utilisateur.Email</div>
                                </div>
                            </div>
                            <div class="text-end">
                                @if (item.Voiture != null)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill small">
                                        <i class="bi bi-car-front me-1"></i>@item.Voiture.Modele
                                    </span>
                                }
                                @if (item.Agence != null)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill small">
                                        <i class="bi bi-geo-alt me-1"></i>@item.Agence.Nom
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Admin moderation -->
                        @if (User.IsInRole("AgenceAdmin") || User.IsInRole("SuperAdmin"))
                        {
                            <div class="d-flex gap-2 mt-3 pt-3 border-top">
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-outline-danger btn-sm rounded-pill px-3 ms-auto">
                                    <i class="bi bi-trash me-1"></i>Supprimer
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
