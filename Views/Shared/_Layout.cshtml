<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyCars</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-blur">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="text-primary">Easy</span>Cars
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Voitures" asp-action="Index">Voitures</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Agences" asp-action="Index">Agences</a>
                        </li>
                        @if (User.IsInRole("AgenceAdmin") || User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-premium dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                                    <li><a class="dropdown-item" asp-controller="Reservations" asp-action="Index"><i class="bi bi-calendar-check me-2"></i>Mes Réservations</a></li>
                                    <li><a class="dropdown-item" asp-controller="Feedbacks" asp-action="Index"><i class="bi bi-star me-2"></i>Mes Avis</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">Déconnexion</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Account" asp-action="Login">Connexion</a>
                            <a class="btn btn-premium rounded-pill px-4" asp-controller="Account" asp-action="Register">S'inscrire</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Toast Notifications -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="liveToast" class="toast glass" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-transparent border-bottom-0">
                <strong class="me-auto text-primary"><i class="bi bi-bell-fill"></i> Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                Contenu de la notification...
            </div>
        </div>
    </div>

    <footer class="py-5 bg-dark text-white mt-5">
        <div class="container text-center">
            <h4 class="fw-bold mb-4">EasyCars</h4>
            <p class="text-muted mb-4">La plateforme multi-agences pour vos locations en toute simplicité.</p>
            <div class="d-flex justify-content-center gap-3 mb-4">
                <a href="#" class="text-white fs-4"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-twitter-x"></i></a>
                <a href="#" class="text-white fs-4"><i class="bi bi-instagram"></i></a>
            </div>
            <hr class="opacity-25 mb-4">
            <p class="mb-0">&copy; 2026 EasyCars Platform. Tous droits réservés.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveNotification", (message) => {
            const toastElement = document.getElementById('liveToast');
            document.getElementById('toastMessage').innerText = message;
            const toast = new bootstrap.Toast(toastElement);
            toast.show();
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
