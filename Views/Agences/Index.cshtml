@model IEnumerable<EasyCars.Models.Agence>

@{
    ViewData["Title"] = "Nos Agences";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5 animate-fade-in">
        <div>
            <h1 class="fw-bold">Nos Agences Partenaires</h1>
            <p class="text-muted">Retrouvez-nous partout en France pour vos besoins de mobilité.</p>
        </div>
        @if (User.IsInRole("SuperAdmin"))
        {
            <a asp-action="Create" class="btn btn-premium">
                <i class="bi bi-plus-lg"></i> Ajouter une agence
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model) {
            <div class="col-md-6 col-lg-4 animate-fade-in">
                <div class="card-premium h-100 d-flex flex-column">
                    <div class="mb-3">
                        <h3 class="h4 fw-bold mb-1">@item.Nom</h3>
                        <p class="text-primary fw-bold mb-3"><i class="bi bi-geo-alt-fill"></i> @item.Ville</p>
                    </div>
                    
                    <div class="mb-4 text-muted small">
                        <i class="bi bi-map"></i> @item.Adresse
                    </div>
                    
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("AgenceAdmin"))
                    {
                        <div class="mt-auto p-3 bg-light rounded-3 mb-3">
                            <span class="small text-muted d-block text-uppercase fw-bold">Chiffre d'Affaires</span>
                            <span class="fs-4 fw-bold text-success">@item.ChiffreAffairesTotal.ToString("C")</span>
                        </div>
                    }
                    
                    <div class="mt-auto d-flex justify-content-between align-items-center">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill px-4">Voir l'agence</a>
                        
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <div class="dropdown">
                                <button class="btn btn-link text-muted" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">Modifier</a></li>
                                    <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id">Supprimer</a></li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
