@model EasyCars.Models.Voiture

@{
    ViewData["Title"] = Model.Modele;
    var badgeClass = Model.Statut switch {
        EasyCars.Models.Enums.StatutVoiture.Disponible => "bg-success",
        EasyCars.Models.Enums.StatutVoiture.Louee => "bg-danger",
        EasyCars.Models.Enums.StatutVoiture.Maintenance => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="container py-5" style="max-width: 800px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Retour à la flotte
        </a>
    </div>

    <div class="card-premium overflow-hidden p-0 mb-4 animate-fade-in">
        <div class="bg-primary text-white p-5 text-center position-relative" style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);">
            <h1 class="display-5 fw-bold mb-0">@Model.Modele</h1>
            <span class="badge @badgeClass position-absolute top-0 end-0 m-4 fs-6 rounded-pill">@Model.Statut</span>
        </div>
        
        <div class="p-5">
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="p-3 rounded-3 text-center h-100" style="background: var(--background);">
                        <i class="bi bi-tag fs-3 text-primary mb-2 d-block"></i>
                        <div class="text-muted small text-uppercase fw-bold mb-1">Tarif</div>
                        <div class="fs-4 fw-bold">@Model.PrixParJour.ToString("C0")<span class="fs-6 text-muted fw-normal">/j</span></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3 text-center h-100" style="background: var(--background);">
                        <i class="bi bi-geo-alt fs-3 text-primary mb-2 d-block"></i>
                        <div class="text-muted small text-uppercase fw-bold mb-1">Agence</div>
                        <div class="fw-bold">@Model.Agence.Nom</div>
                        <div class="small text-muted">@Model.Agence.Ville</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3 text-center h-100" style="background: var(--background);">
                        <i class="bi bi-shield-check fs-3 text-primary mb-2 d-block"></i>
                        <div class="text-muted small text-uppercase fw-bold mb-1">Assurance</div>
                        <div class="fw-bold text-success">Tous risques incluse</div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("AgenceAdmin"))
                {
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-secondary rounded-pill me-2">
                            <i class="bi bi-pencil me-1"></i>Modifier
                        </a>
                    </div>
                }
                
                @if (Model.Statut == EasyCars.Models.Enums.StatutVoiture.Disponible)
                {
                    <a asp-controller="Reservations" asp-action="Create" asp-route-voitureId="@Model.Id" 
                       class="btn btn-premium btn-lg rounded-pill px-5 ms-auto">
                        Réserver maintenant <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg rounded-pill px-5 ms-auto" disabled>
                        <i class="bi bi-lock me-2"></i>Indisponible
                    </button>
                }
            </div>
        </div>
    </div>
</div>
