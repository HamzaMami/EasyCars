@model EasyCars.Models.Voiture

@{
    ViewData["Title"] = "Ajouter un véhicule";
}

<div class="container py-5" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Retour à la flotte
        </a>
    </div>

    <div class="card-premium animate-fade-in">
        <h2 class="fw-bold mb-4">Nouveau Véhicule</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 small"></div>

            <div class="mb-4">
                <label asp-for="Modele" class="form-label fw-bold small text-uppercase text-muted">Modèle du véhicule</label>
                <input asp-for="Modele" class="form-control rounded-3 py-3" placeholder="Ex: Tesla Model 3" style="border: 1.5px solid rgba(100,116,139,0.2);" />
                <span asp-validation-for="Modele" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="PrixParJour" class="form-label fw-bold small text-uppercase text-muted">Prix par jour (€)</label>
                    <input asp-for="PrixParJour" class="form-control rounded-3 py-3" placeholder="0.00" style="border: 1.5px solid rgba(100,116,139,0.2);" />
                    <span asp-validation-for="PrixParJour" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Statut" class="form-label fw-bold small text-uppercase text-muted">Statut Initial</label>
                    <select asp-for="Statut" class="form-select rounded-3 py-3" asp-items="Html.GetEnumSelectList<EasyCars.Models.Enums.StatutVoiture>()" style="border: 1.5px solid rgba(100,116,139,0.2);"></select>
                    <span asp-validation-for="Statut" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="AgenceId" class="form-label fw-bold small text-uppercase text-muted">Agence d'attachement</label>
                <select asp-for="AgenceId" class="form-select rounded-3 py-3" asp-items="ViewBag.AgenceId" style="border: 1.5px solid rgba(100,116,139,0.2);">
                    <option value="">-- Sélectionner une agence --</option>
                </select>
                <span asp-validation-for="AgenceId" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-5">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4">Annuler</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-save me-2"></i>Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

