@model EasyCars.Models.Reservation

@{
    ViewData["Title"] = "Nouvelle Réservation";
}

<div class="container py-5" style="max-width: 680px;">
    <div class="mb-5 animate-fade-in">
        <a asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Retour aux réservations
        </a>
        <h1 class="fw-bold mt-3">Réserver un véhicule</h1>
        <p class="text-muted">Choisissez vos dates et confirmez votre location.</p>
    </div>

    <div class="card-premium animate-fade-in">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 small"></div>

            <!-- Car selection -->
            <div class="mb-4">
                <label asp-for="VoitureId" class="form-label fw-bold small text-uppercase text-muted">Véhicule</label>
                <select asp-for="VoitureId" id="voiture-select" class="form-select rounded-3 py-3"
                        asp-items="ViewBag.VoitureId" style="border: 1.5px solid rgba(100,116,139,0.2);">
                    <option value="">-- Sélectionner un véhicule --</option>
                </select>
                <span asp-validation-for="VoitureId" class="text-danger small"></span>
            </div>

            <!-- Date range -->
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="DateDebut" class="form-label fw-bold small text-uppercase text-muted">Date de début</label>
                    <input asp-for="DateDebut" type="date" id="date-debut" class="form-control rounded-3 py-3"
                           style="border: 1.5px solid rgba(100,116,139,0.2);" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DateDebut" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="DateFin" class="form-label fw-bold small text-uppercase text-muted">Date de fin</label>
                    <input asp-for="DateFin" type="date" id="date-fin" class="form-control rounded-3 py-3"
                           style="border: 1.5px solid rgba(100,116,139,0.2);" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DateFin" class="text-danger small"></span>
                </div>
            </div>

            <!-- Live cost estimate -->
            <div id="cost-preview" class="p-4 rounded-3 mb-4 d-none" style="background: var(--background);">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Durée</span>
                    <span class="fw-bold" id="days-count">–</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Prix / jour</span>
                    <span class="fw-bold" id="price-per-day">–</span>
                </div>
                <div class="d-flex justify-content-between border-top pt-2 mt-1">
                    <span class="fw-bold">Estimation</span>
                    <span class="fs-5 fw-bold text-primary" id="total-estimate">–</span>
                </div>
                <p class="small text-muted mt-2 mb-0"><i class="bi bi-info-circle me-1"></i>La remise fidélité sera appliquée à la confirmation.</p>
            </div>

            <!-- Hidden user field — filled server-side via [Authorize] -->
            <input asp-for="UtilisateurId" type="hidden" />

            <button type="submit" class="btn btn-premium w-100 py-3 fs-6">
                <i class="bi bi-calendar-check me-2"></i>Confirmer la réservation
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Price lookup from the select options (data attribute populated by ViewBag)
        const priceMap = @Html.Raw(ViewBag.PriceMap ?? "{}");

        function updateEstimate() {
            const voitureId = document.getElementById('voiture-select').value;
            const debut = new Date(document.getElementById('date-debut').value);
            const fin   = new Date(document.getElementById('date-fin').value);
            const preview = document.getElementById('cost-preview');

            if (voitureId && !isNaN(debut) && !isNaN(fin) && fin > debut) {
                const days = Math.ceil((fin - debut) / (1000 * 60 * 60 * 24));
                const prix = priceMap[voitureId] || 0;
                const total = days * prix;

                document.getElementById('days-count').textContent = days + ' jour(s)';
                document.getElementById('price-per-day').textContent = prix.toFixed(2) + ' €';
                document.getElementById('total-estimate').textContent = total.toFixed(2) + ' €';
                preview.classList.remove('d-none');
            } else {
                preview.classList.add('d-none');
            }
        }

        document.getElementById('voiture-select').addEventListener('change', updateEstimate);
        document.getElementById('date-debut').addEventListener('change', updateEstimate);
        document.getElementById('date-fin').addEventListener('change', updateEstimate);
    </script>
}

